# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/analytics_db
DATABASE_URL_SYNC=postgresql://postgres:postgres@db:5432/analytics_db

# Redis
REDIS_URL=redis://redis:6379/0

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# Data Generation
SEED=42
MOCK_API_BASE_URL=http://127.0.0.1:8000

# Pagination
DEFAULT_PAGE_SIZE=1000
MAX_PAGE_SIZE=5000

# Ingestion
INGESTION_BATCH_SIZE=5000
INGESTION_CONCURRENCY=10

# Cache
CACHE_TTL_SECONDS=60

# Record counts (used by scripts/generate_data.py)
CUSTOMERS_COUNT=100000
ORDERS_COUNT=1000000
REFUNDS_COUNT=200000
